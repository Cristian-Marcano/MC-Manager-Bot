# ── Discord Bot ────────────────────────────────────────────────
# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-discord-bot-token-here

# Your Discord application/client ID (from the same page as the token)
CLIENT_ID=your-application-client-id-here


# Comma-separated list of Discord server IDs allowed to use this bot.
# How to get a server ID: enable Developer Mode in Discord
#   -> right-click the server icon -> Copy Server ID
# Leave empty or remove to allow ALL servers (not recommended).
ALLOWED_GUILD_IDS=123456789012345678,987654321098765432

# ── Docker ─────────────────────────────────────────────────────
# The exact name of the Minecraft Docker container to manage
CONTAINER_NAME=minecraft-server
